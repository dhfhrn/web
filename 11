<!DOCTYPE html>
<html>
    <head>
        <title> Type Conversion Examples </title>
    </head>
    <body>
        <script type='text/javascript'>
            var length = 123,
                length_num,
                length_str;
            
            length_num = length + 10;
            length_str = length.toString() + 10;

            document.write('Length in Number: ' + length_num + 'cm' + '<br />');
            document.write('Length in Number: ' + length_str + 'cm' + '<br />');

            var num = parseInt(length_str) + 20;
            document.write('Length in Number: ' + num + 'cm')
        </script>
    </body>
</html>

